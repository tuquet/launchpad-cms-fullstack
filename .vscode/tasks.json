{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 cms: dev",
      "type": "shell",
      "command": "yarn dev",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "group": "main"
      },
      "problemMatcher": []
    },
    {
      "label": "🐳 docker: db-up",
      "type": "shell",
      "command": "yarn setup",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "🌱 strapi: seed",
      "type": "shell",
      "command": "yarn seed",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "📦 strapi: dev",
      "type": "shell",
      "command": "yarn strapi",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "🌐 next: dev",
      "type": "shell",
      "command": "yarn next",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "🧹 cms: clean",
      "type": "shell",
      "command": "npx kill-port 3000 1337 && yarn clean && npx rimraf next/.next/dev/lock && yarn dev",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "🔑 registry: login",
      "type": "shell",
      "command": "docker login ${input:registry}",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "🐳 registry: push-strapi",
      "type": "shell",
      "command": "docker build -t ${input:registry}/strapi-app:${input:tag} ./strapi && docker push ${input:registry}/strapi-app:${input:tag}",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "docker-build"
      },
      "problemMatcher": []
    },
    {
      "label": "🐳 registry: push-next",
      "type": "shell",
      "command": "docker build -t ${input:registry}/next-app:${input:tag} ./next && docker push ${input:registry}/next-app:${input:tag}",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "docker-build"
      },
      "problemMatcher": []
    },
    {
      "label": "🐳 registry: push-all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "🐳 registry: push-strapi",
        "🐳 registry: push-next"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "registry",
      "type": "promptString",
      "description": "Registry Address (IP:5000 or Domain)",
      "default": "localhost:5000"
    },
    {
      "id": "tag",
      "type": "promptString",
      "description": "Image Tag (e.g. v1, latest, 2024-05-14)",
      "default": "latest"
    }
  ]
}

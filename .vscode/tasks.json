        "id": "rocket",
        "color": "terminal.ansiYellow"
      }
    },
    {
      "label": "🐳 docker: db-up",
      "type": "shell",
      "command": "yarn setup",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": [],
      "icon": {
        "id": "server-environment",
        "color": "terminal.ansiBlue"
      }
    },
    {
      "label": "🌱 strapi: seed",
      "type": "shell",
      "command": "yarn seed",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": [],
      "icon": {
        "id": "leaf",
        "color": "terminal.ansiGreen"
      }
    },
    {
      "label": "📦 strapi: dev",
      "type": "shell",
      "command": "yarn strapi",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": [],
      "icon": {
        "id": "package",
